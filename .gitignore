# =========================================================
# 敏感密鑰與本地配置：禁止公開 API Key、資料庫密碼、私有推理資料
# =========================================================
.env
.env.*
!.env.example
.reasonix/

# =========================================================
# Python 系統檔、快取與虛擬環境
# =========================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/

# =========================================================
# 測試、覆蓋率與代碼分析快取
# =========================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# =========================================================
# 大數據、圖片快取與本地匯出資料
# =========================================================
data/

# =========================================================
# 資料庫備份、Dump 與部署備份
# =========================================================
*.sql
*.dump
*.backup
deploy/backups/

# =========================================================
# 大型壓縮檔與 Python 打包產物
# =========================================================
*.zip
*.7z
*.tar
*.tar.gz
dist/
build/
*.egg-info/

# =========================================================
# 前端依賴
# =========================================================
node_modules/

# =========================================================
# 作業系統產生的垃圾檔案
# =========================================================
Thumbs.db
desktop.ini
.DS_Store
